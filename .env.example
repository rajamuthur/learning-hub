# Copy this file to ".env" and fill in your values.

# Postgres connection string.
# Neon example: postgresql://user:pass@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: protect editing with a shared passcode.
# Leave blank for fully open editing (no login, as requested).
EDIT_PASSCODE=

# Set to "disable" only when using a local Postgres without SSL.
# PGSSL=disable

# Port (Render sets this automatically).
PORT=3000
